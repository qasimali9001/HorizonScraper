DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
PORT=3001
CRON_ENABLED=true
CRON_SCHEDULE=*/30 * * * *
JOB_SECRET=change-me-long-random-string
SEED_WORLDS=true
COLLECTOR_WORLD_DELAY_MS=15000

# POST /jobs/worldNames/refreshAll with header x-job-secret (when JOB_SECRET is set)
# rewrites World.name from each world page title — use once to backfill names in Supabase.

